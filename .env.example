# ═══════════════════════════════════════════════════════════════
#  Fusion-Jarvis — Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control!
# ═══════════════════════════════════════════════════════════════

# ── Telegram Credentials ─────────────────────────────────────
# Get from: https://my.telegram.org/auth → API Development Tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# Your Telegram phone number (international format, e.g., +84912345678)
TELEGRAM_PHONE=+84912345678

# Optional: Your Telegram User ID (to restrict bot to only respond to you)
# Set to 0 to allow anyone to use the bot
# Get your ID by messaging @userinfobot on Telegram
TELEGRAM_OWNER_ID=0

# ── OpenRouter API ───────────────────────────────────────────
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter base URL (usually no need to change)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ── LLM Model Selection ──────────────────────────────────────
# Main conversation model. Examples:
#   google/gemini-2.0-flash-001      (fast, free tier available)
#   anthropic/claude-3.5-sonnet      (powerful, reasoning)
#   openai/gpt-4o                    (OpenAI GPT-4o)
#   mistralai/mistral-large           (Mistral)
DEFAULT_MODEL=google/gemini-2.0-flash-001

# Model for memory summarization (can be cheaper/faster)
SUMMARIZER_MODEL=google/gemini-2.0-flash-001

# Maximum tokens in AI response
MAX_TOKENS=2048

# ── Memory Settings ──────────────────────────────────────────
# Number of message turns before summarization triggers
SHORT_TERM_LIMIT=10

# ── Agent Identity ───────────────────────────────────────────
AGENT_NAME=Fusion-Jarvis
AGENT_LANGUAGE=Vietnamese/English

# ── Session ──────────────────────────────────────────────────
# Name for the Telethon session file (no extension)
SESSION_NAME=fusion_jarvis_session
