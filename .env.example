# =================================================================
#  FluxClaw -- Environment Variables
#  Copy this file to .env and fill in your actual values.
#  NEVER commit .env to version control!
# =================================================================

# -- Telegram App Credentials -------------------------------------
# Required for Telethon regardless of login mode.
# Get from: https://my.telegram.org/auth -> API Development Tools
TELEGRAM_API_ID=12345678
TELEGRAM_API_HASH=your_api_hash_here

# -- Bot API Mode (recommended) -----------------------------------
# Get a token by messaging @BotFather on Telegram -> /newbot
# This replaces the phone number login entirely.
TELEGRAM_BOT_TOKEN=123456789:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -- UserBot Mode (legacy, leave empty when using Bot Token) ------
# Only needed if you want to log in as a personal account instead.
# TELEGRAM_PHONE=+84912345678

# -- Access Control -----------------------------------------------
# WARNING: Set this to YOUR Telegram User ID to restrict the bot
# to respond ONLY to you. Leaving it as 0 (PUBLIC mode) means
# ANYONE can interact with your bot and drain your OpenRouter
# API quota without limits!
# Get your Telegram User ID by messaging @userinfobot on Telegram.
TELEGRAM_OWNER_ID=0

# -- OpenRouter API -----------------------------------------------
# Get from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenRouter base URL (usually no need to change)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# -- LLM Model Selection ------------------------------------------
# Main conversation model. Examples:
#   google/gemini-2.0-flash-001      (fast, free tier available)
#   anthropic/claude-3.5-sonnet      (powerful, reasoning)
#   openai/gpt-4o                    (OpenAI GPT-4o)
#   mistralai/mistral-large          (Mistral)
DEFAULT_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Optional fallback chain (comma-separated) used automatically on 429/404
FALLBACK_MODELS=google/gemini-2.0-flash-001,meta-llama/llama-3.1-8b-instruct:free

# Model for memory summarization (can be cheaper/faster)
SUMMARIZER_MODEL=meta-llama/llama-3.1-8b-instruct

# Maximum tokens in AI response
MAX_TOKENS=2048

# -- Memory Settings ----------------------------------------------
# Number of message turns before summarization triggers
SHORT_TERM_LIMIT=10

# -- Agent Identity -----------------------------------------------
AGENT_NAME=FluxClaw
AGENT_LANGUAGE=Vietnamese/English

# -- Session ------------------------------------------------------
# Name for the Telethon session file (no extension needed)
SESSION_NAME=fluxclaw_session
